{
  "name": "ctrl-zebra",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.11.0",
  "scripts": {
    "build": "pnpm --recursive --if-present run build",
    "check": "biome ci .",
    "package:vsix": "node ./apps/extension/scripts/package-vsix.mjs",
    "smoke:vsix": "node ./apps/extension/scripts/smoke-test-vsix.mjs",
    "test": "pnpm run test:unit && pnpm run test:integration",
    "test:integration": "pnpm --filter ./apps/extension run test:integration",
    "test:unit": "vitest run",
    "typecheck": "pnpm --recursive exec tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@vscode/vsce": "3.9.2",
    "typescript": "6.0.2",
    "vitest": "4.1.6",
    "yauzl": "3.4.0"
  }
}
